---
import BaseHead from '@site-components/base-head/base-head.astro';
import SidebarList from '@site-components/side-bar-list/side-bar-list.astro';
import Navbar from '@site-components/navbar/navbar.astro';
---

<BaseHead
	title="UI Components"
	description="A list of simple, well designer, accessible components"
/>

<Navbar />
<div class="components-view">
	<div class="components-view__sidebar">
		<SidebarList />
	</div>
	<div class="components-view__right-col">
		<slot />
	</div>
</div>
<style>
	.components-view {
		min-height: 100vh;
		padding-top: var(--spacing-xl);
	}

	.components-view__sidebar {
		background-color: hsla(229, 27%, 8%, 0.8);
		position: fixed;
		top: 0;
		width: 100%;
		height: 100%;
		overflow: scroll;
		z-index: 15;
		transform: translateX(-100%);
		transition: var(--transition-medium) ease-in-out;
	}

	.components-view__sidebar[data-menu-state='open'] {
		opacity: 1;
		transform: translateX(0);
		transition: var(--transition-medium) ease-in-out;
	}

	.components-view__right-col {
		flex-grow: 1;
		margin-left: 0;
		transition: var(--transition-medium) ease-in-out;
	}

	@media (min-width: 768px) {
		.components-view__sidebar {
			opacity: 1;
			width: 250px;
			transform: translateX(0%);
		}

		.components-view__sidebar-content {
			transform: translateX(0);
		}

		.components-view__right-col {
			margin-left: 255px;
		}
	}
</style>
