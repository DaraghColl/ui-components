<style>
	.rating {
		display: flex;
		gap: var(--spacing-md);
	}

	.rating__star {
		width: 2rem;
		height: 2rem;
		color: var(--color-font);
		cursor: pointer;
		transition: var(--transition-short) ease-in-out;
	}

	.rating__star-active {
		animation: star-active 0.5s ease-in forwards;
	}

	@media (min-width: 768px) {
		.rating__star:hover {
			transform: translateY(-0.25rem);
			transition: var(--transition-short) ease-in-out;
		}
	}

	@keyframes star-active {
		0% {
			scale: 0.5;
			color: gold;
			fill: gold;
		}

		50% {
			scale: 1.2;
		}

		100% {
			scale: 1;
			color: gold;
			fill: gold;
		}
	}
</style>

<script lang="js">
	(function dropdownInit() {
		const stars = document.querySelectorAll('.rating__star');

		const removeStars = () => {
			stars.forEach((star, index) => {
				star.classList.remove('rating__star-active');
			});
		};

		stars.forEach((star, index) => {
			star.addEventListener('click', (e) => {
				removeStars();

				for (let i = 0; i <= index; i++) {
					setTimeout(() => {
						stars[i].classList.add('rating__star-active');
					}, 200 * i);
				}
			});
		});
	})();
</script>
