<div class="video-card" id="video_card">
	<div class="video-card__overlay"></div>
	<h1 class="video-card__heading">Donegal</h1>
	<video playsinline muted loop id="video">
		<source src="/video-card.mp4" type="video/mp4" />
		Your browser does not support the video tag.
	</video>
</div>

<style>
	.video-card {
		position: relative;
		border-radius: var(--rounded-md);
		cursor: pointer;
	}

	.video-card__overlay {
		position: absolute;
		width: 100%;
		height: 100%;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: hsla(229, 27%, 8%, 0.8);
		transition: background-color var(--transition-short) ease-in-out;
	}

	.video-card:hover .video-card__overlay {
		background-color: hsla(229, 27%, 8%, 0.3);
		transition: background-color var(--transition-short) ease-in-out;
	}

	.video-card__heading {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		color: white;
		font-size: var(--font-xl);
	}

	.video-card video {
		display: block;
		width: 100%;
		border-radius: var(--rounded-md);
	}

	@media (min-width: 768px) {
		.video-card__heading {
			font-size: var(--font-3xl);
		}
	}
</style>

<script lang="js">
	(function videoInit() {
		const cardVideo = document.getElementById('video_card');
		const video = document.getElementById('video');

		cardVideo.addEventListener('mouseover', () => {
			video.play();
		});

		cardVideo.addEventListener('mouseout', () => {
			video.pause();
			video.currentTime = 0;
		});
	})();
</script>
